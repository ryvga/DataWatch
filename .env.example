# ── Application ────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
FERNET_MASTER_KEY=generate-with-cryptography-fernet-generate-key
ENVIRONMENT=development
LOG_LEVEL=INFO

# ── Multi-tenancy ──────────────────────────────────────────────────────────────
BASE_DOMAIN=datawatch.io
ADMIN_SUBDOMAIN=admin

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://datawatch:datawatch@postgres:5432/datawatch

# ── Redis / Celery ─────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── AI — global fallback (per-org keys set via admin portal) ──────────────────
# LLM narration uses per-org key if set, falls back to this
OPENROUTER_API_KEY=sk-or-v1-...
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=nvidia/nemotron-3-super-120b-a12b:free

# ── Staff seed — first staff account bootstrapped on startup ───────────────────
# Set STAFF_PASSWORD to trigger seeding. Leave blank to skip.
STAFF_EMAIL=admin@datawatch.io
STAFF_PASSWORD=
STAFF_FULL_NAME=DataWatch Admin

# ── Email (MailHog for local dev) ──────────────────────────────────────────────
# docker-compose.yml injects SMTP_HOST=mailhog for api/worker automatically.
# Override here only if running outside Docker.
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USE_TLS=false
SMTP_USERNAME=
SMTP_PASSWORD=
FROM_EMAIL=noreply@panopta.app
APP_BASE_URL=http://localhost:5173

# For production, point at a real SMTP relay (SendGrid SMTP, SES, Mailgun…):
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USE_TLS=true
# SMTP_USERNAME=apikey
# SMTP_PASSWORD=SG....

# ── Key generation (run these to generate values above) ───────────────────────
# python -c "import secrets; print(secrets.token_hex(32))"
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
