# ── Application ────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
FERNET_MASTER_KEY=generate-with-cryptography-fernet-generate-key
ENVIRONMENT=development
LOG_LEVEL=INFO

# ── Multi-tenancy ──────────────────────────────────────────────────────────────
BASE_DOMAIN=datawatch.io
ADMIN_SUBDOMAIN=admin

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://datawatch:datawatch@postgres:5432/datawatch

# ── Redis / Celery ─────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── AI — global fallback (per-org keys set via admin portal) ──────────────────
# LLM narration uses per-org key if set, falls back to this
OPENROUTER_API_KEY=sk-or-v1-...
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=nvidia/nemotron-3-super-120b-a12b:free

# ── Staff seed — first staff account bootstrapped on startup ───────────────────
# Set STAFF_PASSWORD to trigger seeding. Leave blank to skip.
STAFF_EMAIL=admin@datawatch.io
STAFF_PASSWORD=
STAFF_FULL_NAME=DataWatch Admin

# ── Email alerts ───────────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG....
FROM_EMAIL=alerts@datawatch.io

# ── Key generation (run these to generate values above) ───────────────────────
# python -c "import secrets; print(secrets.token_hex(32))"
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
